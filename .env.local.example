# MemeCMO.ai app — local / Vercel environment variables
# Copy to .env.local for local dev. Set the same in Vercel project settings for prod.

# ── Supabase ──────────────────────────────────────────────────
# Get from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# DATABASE_URL used by scripts/run-migrations.sh
# Get from Supabase dashboard → Project Settings → Database → Connection string (URI / pooler)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Resend (email) ────────────────────────────────────────────
# Reuse the same key already configured for memecmo.ai (static site) if desired
RESEND_API_KEY=re_...

# ── Poe (LLM router) ──────────────────────────────────────────
# Same key the guanlan / observation builds used. From poe.com/api_key
POE_API_KEY=...

# ── Stripe ────────────────────────────────────────────────────
# Use test keys in dev, live keys in production
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: publishable key (only needed if doing client-side Stripe.js)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Upstash Redis (rate limiting + caching) ───────────────────
# Create a fresh database at console.upstash.com → Redis
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Site URL ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://app.memecmo.ai
